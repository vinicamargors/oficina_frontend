# Copy this file to .env.local and fill the real values (do NOT commit .env.local)
# Values prefixed with NEXT_PUBLIC will be exposed to the browser in Next.js

# Supabase (public - used by client)
NEXT_PUBLIC_SUPABASE_URL=your-supabase-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase (server-only, optional)
SUPABASE_URL=your-supabase-url
SUPABASE_KEY=your-service-role-key

# Example:
# NEXT_PUBLIC_SUPABASE_URL=https://abcd.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJI...
